# OpenAI API Key for AI-powered code validation
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_api_key_here

# Firebase Configuration for Cloud Authentication and Data Sync
# Get your config from Firebase Console:
# 1. Go to https://console.firebase.google.com/
# 2. Create a new project (or use existing)
# 3. Click "Add app" > "Web app"
# 4. Copy the firebaseConfig values below
# 5. Enable Authentication > Sign-in method > Email/Password and Google
# 6. Enable Firestore Database > Create database > Start in test mode

VITE_FIREBASE_API_KEY=your-firebase-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
